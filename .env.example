# Copy this file to .env and fill in real values locally
# Never commit .env to GitHub

# Supabase
NEXT_PUBLIC_SUPABASE_URL=            # Supabase project URL (public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=       # Supabase anon/public API key
SUPABASE_SERVICE_ROLE_KEY=           # Supabase service-role key (server-only, secret)

# AI
ANTHROPIC_API_KEY=                   # Anthropic API key for note tidying

# Email (Resend)
RESEND_API_KEY=                      # Resend API key for transactional email
RESEND_FROM_EMAIL=                   # From address used when sending email

# App
APP_URL=                             # Base URL of the app (server-side)
NEXT_PUBLIC_APP_URL=                 # Base URL of the app (client-exposed)

# Cron
CRON_SECRET=                         # Shared secret to authenticate the reminders cron endpoint
